{
  "name": "car-config-embed",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "test:build": "pnpm build && pnpm dlx serve -l 3333",
    "serve:test": "pnpm dlx serve -l 3333",
    "docs:dev": "vitepress dev docs",
    "docs:build": "pnpm build && pnpm docs:copy && vitepress build docs",
    "docs:copy": "mkdir -p docs/public/widget && cp dist/car-config-embed.iife.js docs/public/widget/",
    "docs:preview": "vitepress preview docs"
  },
  "dependencies": {
    "solid-js": "^1.9.10"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^24.10.1",
    "@vueuse/core": "^14.2.1",
    "eslint": "^10.0.2",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-solid": "^0.14.5",
    "globals": "^17.3.0",
    "monaco-editor": "^0.55.1",
    "tailwindcss": "^4.0.0",
    "terser": "^5.37.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.3.1",
    "vite-plugin-css-injected-by-js": "^3.5.2",
    "vite-plugin-solid": "^2.11.10",
    "vitepress": "^1.6.4",
    "vue": "^3.5.29"
  }
}
